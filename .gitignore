# public/media/

# File di Log e Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# File generati dal Sistema Operativo (Mac/Windows)
.DS_Store
Thumbs.db

# File di cache di TypeScript e ESLint
*.tsbuildinfo
.eslintcache

# Tooling (es. Vercel)
.vercel
next-env.d.ts

# Playwright
/test-results/
