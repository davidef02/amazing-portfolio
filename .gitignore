# Dipendenze
/node_modules
/.pnp
.pnp.js

# File temporanei ed eseguibili di Next.js
/.next/
/out/
/build
dist/

# File di ambiente e chiavi segrete (FONDAMENTALE per il DB Supabase)
.env
.env*.local
.env.development.local
.env.test.local
.env.production.local

# File Media di Payload (di default non vanno pushati se usi cloud storage, altrimenti sì)
